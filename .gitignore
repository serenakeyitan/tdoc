# tdoc skill — files generated locally per user, never committed

# Per-user Cloudflare config (contains upload token)
.tdoc/
~/.tdoc/

# Bundled worker output (generated by bin/tdoc-publish on every deploy)
worker/_worker.bundled.js
worker/wrangler.toml

# Wrangler local cache (created by `wrangler deploy`) — never commit
worker/.wrangler/

# Vercel local artifacts (project link + generated bundle) — the real deploy
# runs from ~/.tdoc/vercel-app, but guard against a stray `vercel` run here
vercel/.vercel/
vercel/_worker.bundled.js
vercel/node_modules/

# Editor / OS junk
.DS_Store
.vscode/
*.swp
*.swo

# Node
node_modules/
npm-debug.log
yarn-error.log

# Telemetry runtime artifacts (per-user, never commit)
telemetry/supabase/.temp/
.gstack/

# Local marketing assets (Twitter cover + Remotion demo video project) — kept
# local, not version-controlled. NOTE: not backed up to GitHub.
marketing/
