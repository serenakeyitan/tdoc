# tdoc skill — files generated locally per user, never committed

# Per-user Cloudflare config (contains upload token)
.tdoc/
~/.tdoc/

# Bundled worker output (generated by bin/tdoc-publish on every deploy)
worker/_worker.bundled.js
worker/wrangler.toml

# Editor / OS junk
.DS_Store
.vscode/
*.swp
*.swo

# Node
node_modules/
npm-debug.log
yarn-error.log
