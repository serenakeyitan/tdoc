# skill-telemetry config — fill in YOUR Supabase project, then save as
# `supabase/config.sh` (NOT .example). The .gitignore in this template
# already excludes config.sh.
#
# These are PUBLIC keys (anon/publishable). Safe to commit — Supabase RLS
# denies all direct access. The actual inserts go through your edge
# function, which uses the service-role key (which stays in Supabase secrets
# and never appears in this file).
#
# Find these in your Supabase project:
#   Dashboard → Settings → API
#     Project URL  → SKILL_TELEMETRY_SUPABASE_URL
#     anon public  → SKILL_TELEMETRY_ANON_KEY

export SKILL_TELEMETRY_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
export SKILL_TELEMETRY_ANON_KEY="YOUR-ANON-PUBLIC-KEY"
