#!/usr/bin/env bash
# telemetry-update-check — check if skill-telemetry has a newer release.
#
# Borrowed from gstack-update-check pattern. Designed to be called from
# telemetry-log on every skill run, but cached so it only actually hits
# GitHub once per 24h. Safe to call 1000x/day.
#
# Output (one line, or nothing):
#   UP_TO_DATE <version>            — local matches latest release
#   UPGRADE_AVAILABLE <old> <new>   — local < latest release
#   AHEAD <local> <latest>          — local > latest (dev build; quiet)
#   (nothing)                       — disabled, snoozed, or check failed
#
# Env:
#   SKILL_TELEMETRY_UPDATE=off     — disable update checks entirely
#   SKILL_TELEMETRY_DIR            — override state dir
#   SKILL_TELEMETRY_VERSION_FILE   — override path to VERSION file
#   SKILL_TELEMETRY_REMOTE_VERSION — override remote VERSION URL (for testing)
#   SKILL_TELEMETRY_CHECK_HOURS    — override cache TTL (default: 24)
#
# Cached at $SKILL_TELEMETRY_DIR/.update-check
# Snooze file: $SKILL_TELEMETRY_DIR/.update-snoozed (one version per line)

set -uo pipefail

# Master disable
[ "${SKILL_TELEMETRY_UPDATE:-on}" = "off" ] && exit 0

# Resolve state dir (per-skill, but we'll also write a shared per-author
# update cache at ~/.skill-telemetry/ to dedupe checks across skills)
SHARED_STATE="${SKILL_TELEMETRY_SHARED_DIR:-$HOME/.skill-telemetry}"
mkdir -p "$SHARED_STATE" 2>/dev/null || exit 0

CACHE_FILE="$SHARED_STATE/.update-check"
SNOOZE_FILE="$SHARED_STATE/.update-snoozed"

# Resolve local version. The caller (telemetry-log) passes its own bin
# directory; from there we find the repo's VERSION file.
BIN_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
LOCAL_VERSION_FILE="${SKILL_TELEMETRY_VERSION_FILE:-$BIN_DIR/../VERSION}"
LOCAL=""
[ -f "$LOCAL_VERSION_FILE" ] && LOCAL="$(cat "$LOCAL_VERSION_FILE" 2>/dev/null | tr -d '[:space:]')"
# If no VERSION file (e.g. bin copied into a target skill without VERSION),
# fall back to a built-in default that says "unknown"
[ -z "$LOCAL" ] && LOCAL="unknown"

REMOTE_URL="${SKILL_TELEMETRY_REMOTE_VERSION:-https://raw.githubusercontent.com/serenakeyitan/skill-telemetry/main/VERSION}"

# ─── Cache hit fast path ─────────────────────────────────────
# If we already checked recently, emit cached answer (no network).
CHECK_HOURS="${SKILL_TELEMETRY_CHECK_HOURS:-24}"
case "$CHECK_HOURS" in ''|*[!0-9]*) CHECK_HOURS=24 ;; esac
CHECK_MIN=$(( CHECK_HOURS * 60 ))

if [ -f "$CACHE_FILE" ]; then
  # Is it fresh?
  STALE="$(find "$CACHE_FILE" -mmin +"$CHECK_MIN" 2>/dev/null || true)"
  if [ -z "$STALE" ]; then
    cat "$CACHE_FILE" 2>/dev/null
    exit 0
  fi
fi

# ─── Slow path: fetch latest remote VERSION ──────────────────
REMOTE="$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null | tr -d '[:space:]' || true)"

# Validate: must look like a version number
if ! echo "$REMOTE" | grep -qE '^[0-9]+\.[0-9.]+$'; then
  # Network error / invalid response — don't refresh cache, exit quiet
  exit 0
fi

# Local was unparseable? Don't compare; just cache + report
if [ "$LOCAL" = "unknown" ]; then
  echo "UP_TO_DATE $REMOTE" > "$CACHE_FILE"
  exit 0
fi

# ─── Compare versions with sort -V (semver-aware) ────────────
if [ "$LOCAL" = "$REMOTE" ]; then
  echo "UP_TO_DATE $LOCAL" > "$CACHE_FILE"
  exit 0
fi

HIGHER="$(printf '%s\n%s\n' "$LOCAL" "$REMOTE" | sort -V | tail -1)"
if [ "$HIGHER" = "$LOCAL" ]; then
  # Local is dev build, ahead of release. Quiet.
  echo "AHEAD $LOCAL $REMOTE" > "$CACHE_FILE"
  exit 0
fi

# REMOTE is strictly newer
echo "UPGRADE_AVAILABLE $LOCAL $REMOTE" > "$CACHE_FILE"

# Snooze check — if user has snoozed this specific version, stay quiet
if [ -f "$SNOOZE_FILE" ]; then
  if grep -qx "$REMOTE" "$SNOOZE_FILE" 2>/dev/null; then
    exit 0
  fi
fi

# Emit the upgrade signal
echo "UPGRADE_AVAILABLE $LOCAL $REMOTE"
