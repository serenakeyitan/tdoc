#!/usr/bin/env bash
# telemetry-upgrade-decide — gstack-style upgrade decision recorder.
#
# Called by host skill's preamble AFTER Claude (the model) calls
# AskUserQuestion and gets a user choice. Persists the choice to
# ~/.skill-telemetry/.upgrade-mode so future runs don't re-prompt.
#
# Usage:
#   telemetry-upgrade-decide always           # auto-upgrade silently from now on
#   telemetry-upgrade-decide never            # never auto-upgrade, never prompt again
#   telemetry-upgrade-decide snooze <version> # snooze this specific version (24h)
#   telemetry-upgrade-decide once <version>   # upgrade this once (then re-prompt next time)
#   telemetry-upgrade-decide status           # print current mode
#
# Companion: telemetry-log reads this state and either silently auto-pulls
# (mode=always) or prints UPGRADE_PROMPT_NEEDED <old> <new> for Claude
# to detect and AskUserQuestion (mode=ask).

set -uo pipefail

SHARED="${SKILL_TELEMETRY_SHARED_DIR:-$HOME/.skill-telemetry}"
mkdir -p "$SHARED" 2>/dev/null || exit 1
MODE_FILE="$SHARED/.upgrade-mode"
SNOOZE_FILE="$SHARED/.upgrade-snoozed"

ACTION="${1:-status}"

case "$ACTION" in
  always)
    echo "always" > "$MODE_FILE"
    echo "✅ Set upgrade mode to 'always' — telemetry will auto-update on every check."
    ;;

  never)
    echo "never" > "$MODE_FILE"
    echo "✅ Set upgrade mode to 'never' — telemetry will never prompt or auto-update."
    ;;

  snooze)
    VERSION="${2:-}"
    if [ -z "$VERSION" ]; then
      echo "ERROR: snooze requires a version, e.g. 'telemetry-upgrade-decide snooze 0.5.0'" >&2
      exit 1
    fi
    # Escalating backoff: first snooze 24h, second 48h, third+ 168h (1 week)
    # NOTE: grep -c prints "0" on no-match AND exits non-zero. The previous
    # `|| echo 0` fallback ran in addition, producing the two-line string
    # "0\n0" which fell through to the "*" case (168h instead of 24h).
    # Fix: redirect stderr but accept grep's "0" output as authoritative.
    if [ -f "$SNOOZE_FILE" ]; then
      EXISTING_SNOOZES=$(grep -c "^$VERSION " "$SNOOZE_FILE" 2>/dev/null)
      [ -z "$EXISTING_SNOOZES" ] && EXISTING_SNOOZES=0
    else
      EXISTING_SNOOZES=0
    fi
    case "$EXISTING_SNOOZES" in
      0) HOURS=24 ;;
      1) HOURS=48 ;;
      *) HOURS=168 ;;
    esac
    UNTIL=$(( $(date +%s) + HOURS * 3600 ))
    echo "$VERSION $UNTIL" >> "$SNOOZE_FILE"
    echo "✅ Snoozed v$VERSION for ${HOURS}h"
    ;;

  once)
    # User chose "Yes, upgrade now" once. This action only busts the
    # update-check cache so they re-prompt on the NEXT new version.
    # The actual upgrade is applied by the host SKILL.md preamble,
    # which calls `skill-telemetry-update --include <skill>` after
    # running this command. See SKILL.md.snippet for the pattern.
    # We deliberately don't write the mode file → stays mode=ask.
    rm -f "$SHARED/.update-check" 2>/dev/null || true
    echo "✅ Cache cleared; host skill should now apply update via skill-telemetry-update"
    ;;

  ask|reset)
    # Reset to default state
    rm -f "$MODE_FILE" 2>/dev/null || true
    echo "✅ Reset to default (will prompt on next detected upgrade)"
    ;;

  status)
    MODE="$(cat "$MODE_FILE" 2>/dev/null || echo ask)"
    echo "Current upgrade mode: $MODE"
    if [ -f "$SNOOZE_FILE" ] && [ -s "$SNOOZE_FILE" ]; then
      echo ""
      echo "Active snoozes:"
      NOW=$(date +%s)
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        SVER=$(echo "$line" | awk '{print $1}')
        SUNTIL=$(echo "$line" | awk '{print $2}')
        if [ "$NOW" -lt "$SUNTIL" ] 2>/dev/null; then
          REMAINING=$(( (SUNTIL - NOW) / 3600 ))
          echo "  v$SVER: ${REMAINING}h remaining"
        fi
      done < "$SNOOZE_FILE"
    fi
    ;;

  *)
    echo "Unknown action: $ACTION" >&2
    echo "Valid actions: always, never, snooze <version>, once, ask, status" >&2
    exit 2
    ;;
esac
