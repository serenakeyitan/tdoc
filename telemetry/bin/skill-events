#!/usr/bin/env bash
# skill-events — query your skill_events table in your local timezone.
#
# Storage is always UTC (best practice — preserves the absolute moment
# in time across timezones). This helper converts to local for display.
#
# TZ detection priority:
#   1. $TZ env var (e.g. TZ=Asia/Shanghai skill-events)
#   2. macOS / Linux: readlink /etc/localtime → IANA name
#   3. Fallback: UTC
#
# Required env (or read from telemetry config file):
#   SKILL_TELEMETRY_SUPABASE_URL — your project URL
#   SUPABASE_ACCESS_TOKEN        — Management API PAT (or read from keychain on macOS)
#
# Usage:
#   skill-events                          # recent 20 events in local TZ
#   skill-events --tz Asia/Shanghai       # override timezone
#   skill-events --limit 100              # more rows
#   skill-events --skill tdoc             # filter to one skill
#   skill-events --failures               # only error/abandoned

set -euo pipefail

# ─── Detect timezone ────────────────────────────────────────
detect_tz() {
  if [ -n "${TZ:-}" ]; then
    echo "$TZ"
    return
  fi
  if [ -L /etc/localtime ]; then
    readlink /etc/localtime 2>/dev/null | sed -E 's|.*/zoneinfo/||'
    return
  fi
  echo "UTC"
}

# ─── Parse args ──────────────────────────────────────────────
TZ_NAME="$(detect_tz)"
LIMIT=20
SKILL_FILTER=""
FAILURES_ONLY=0

while [ $# -gt 0 ]; do
  case "$1" in
    --tz)        TZ_NAME="$2"; shift 2 ;;
    --limit)     LIMIT="$2"; shift 2 ;;
    --skill)     SKILL_FILTER="$2"; shift 2 ;;
    --failures)  FAILURES_ONLY=1; shift ;;
    -h|--help)
      head -22 "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *)
      echo "unknown arg: $1" >&2
      exit 2
      ;;
  esac
done

# ─── Resolve project ref from URL ───────────────────────────
# Look at env first, then any installed skill's telemetry config
# (the URL is the same across all skills that share one Supabase pool).
CONFIG=""
if [ -z "${SKILL_TELEMETRY_SUPABASE_URL:-}" ]; then
  # Search ~/.claude/skills/*/telemetry/supabase/config.sh
  for cand in $HOME/.claude/skills/*/telemetry/supabase/config.sh; do
    [ -f "$cand" ] && CONFIG="$cand" && break
  done
  # Fallback: explicit known paths
  if [ -z "$CONFIG" ]; then
    for cand in \
      "$HOME/code/skill-telemetry/supabase/config.sh" \
      "$HOME/.claude/skills/skill-telemetry/supabase/config.sh"; do
      [ -f "$cand" ] && CONFIG="$cand" && break
    done
  fi
  [ -n "$CONFIG" ] && . "$CONFIG"
fi

URL="${SKILL_TELEMETRY_SUPABASE_URL:-}"
[ -z "$URL" ] && { echo "FATAL: SKILL_TELEMETRY_SUPABASE_URL not set (and no config.sh found)"; exit 1; }
PROJECT_REF="$(echo "$URL" | sed -n 's|https://\([a-z0-9]*\)\.supabase\.co.*|\1|p')"
[ -z "$PROJECT_REF" ] && { echo "FATAL: couldn't parse project ref from $URL"; exit 1; }

# ─── Resolve access token (Management API needs PAT) ────────
ACCESS_TOKEN="${SUPABASE_ACCESS_TOKEN:-}"
if [ -z "$ACCESS_TOKEN" ]; then
  case "$(uname -s)" in
    Darwin)
      RAW=$(security find-generic-password -s "Supabase CLI" -w 2>/dev/null || true)
      B64=${RAW#go-keyring-base64:}
      ACCESS_TOKEN=$(echo "$B64" | base64 -D 2>/dev/null || echo "$B64" | base64 --decode 2>/dev/null || echo "")
      ;;
    Linux)
      for tokfile in "$HOME/.supabase/access-token" "$HOME/.config/supabase/access-token"; do
        [ -f "$tokfile" ] && ACCESS_TOKEN="$(cat "$tokfile")" && break
      done
      ;;
  esac
fi
[ -z "$ACCESS_TOKEN" ] && { echo "FATAL: no SUPABASE_ACCESS_TOKEN. Run 'supabase login' or export the env var."; exit 1; }

# ─── Build SQL ──────────────────────────────────────────────
SQL="select to_char(ts_local, 'YYYY-MM-DD HH24:MI:SS') as t, skill, coalesce(skill_version, '-') as ver, coalesce(event_type, 'skill_run') as evt, outcome, coalesce(step, '-') as step, case when duration_s is null then '-' else duration_s::text end as dur, coalesce(error_class, '') as err_class, coalesce(error_message, '') as err_msg from skill_events_in_tz('$TZ_NAME')"

WHERE_PARTS=()
[ -n "$SKILL_FILTER" ] && WHERE_PARTS+=("skill = '$SKILL_FILTER'")
[ "$FAILURES_ONLY" = "1" ] && WHERE_PARTS+=("outcome in ('error','abandoned')")

if [ ${#WHERE_PARTS[@]} -gt 0 ]; then
  WHERE_CLAUSE=$(IFS=' and '; echo "${WHERE_PARTS[*]}")
  SQL="$SQL where $WHERE_CLAUSE"
fi
SQL="$SQL limit $LIMIT"

# ─── Query + render ─────────────────────────────────────────
echo "TZ: $TZ_NAME"
echo

RESP=$(curl -s --max-time 15 \
  -X POST "https://api.supabase.com/v1/projects/${PROJECT_REF}/database/query" \
  -H "Authorization: Bearer $ACCESS_TOKEN" \
  -H "Content-Type: application/json" \
  -d "$(jq -n --arg q "$SQL" '{query: $q}')")

if echo "$RESP" | jq -e 'type == "array" and length > 0' >/dev/null 2>&1; then
  echo "$RESP" | jq -r '
    (["TIME","SKILL","VER","EVENT","OUTCOME","STEP","DUR","ERR_CLASS","ERR_MSG"]),
    (["----","-----","---","-----","-------","----","---","---------","-------"]),
    (.[] | [.t, .skill, .ver, .evt, .outcome, .step, .dur, .err_class, (.err_msg | if length > 40 then .[:37] + "..." else . end)])
    | @tsv' | column -t -s $'\t'
elif echo "$RESP" | jq -e 'type == "array"' >/dev/null 2>&1; then
  echo "(no rows match)"
else
  echo "API error:"
  echo "$RESP" | jq . 2>/dev/null || echo "$RESP"
fi
