#!/usr/bin/env bash
# telemetry-log — append a skill-invocation event to local JSONL, then
# fire telemetry-sync in the background.
#
# Called by the skill itself from its SKILL.md "TELEMETRY" section at the
# end of a run. The skill knows what it is and how it went; this script
# just records it honestly.
#
# Usage:
#   telemetry-log --skill <name> [--outcome success|error|abandoned|unknown]
#                 [--duration <int seconds>] [--error-detail <≤160 chars>]
#                 [--step <step-name>] [--session-id <id>]
#
# Env:
#   SKILL_TELEMETRY=off          — disables ALL writing and sync (overrides everything)
#   SKILL_TELEMETRY=anonymous    — sends events but strips installation_id
#   SKILL_TELEMETRY=on           — sends everything (default)
#   SKILL_TELEMETRY_DIR          — override state dir (default: ~/.<skill>)
#   SKILL_TELEMETRY_BIN          — override bin dir (default: dir of this script)
#
# Persistent mode (~/.<skill>/.telemetry-mode) is read if env var not set.
# Written by the preamble in the host skill's SKILL.md on first run.
#
# Failure mode: never exits non-zero. Telemetry must not break the skill.

set -uo pipefail

# ─── Determine effective mode (env > persisted > default) ────
# We need $SKILL to find the persisted config, but $SKILL comes from args.
# So peek at args first just to extract --skill, then resolve mode.
PEEK_SKILL=""
for ((i=1; i<=$#; i++)); do
  if [ "${!i:-}" = "--skill" ]; then
    next=$((i + 1))
    PEEK_SKILL="${!next:-}"
    break
  fi
done

if [ -n "${SKILL_TELEMETRY:-}" ]; then
  MODE="$SKILL_TELEMETRY"
elif [ -n "$PEEK_SKILL" ] && [ -f "$HOME/.${PEEK_SKILL}/.telemetry-mode" ]; then
  MODE="$(cat "$HOME/.${PEEK_SKILL}/.telemetry-mode" 2>/dev/null | tr -d ' \n\r')"
else
  MODE="on"
fi

# Validate mode
case "$MODE" in
  on|anonymous|off) ;;
  *) MODE="on" ;;
esac

# Master kill switch
[ "$MODE" = "off" ] && exit 0

# ─── Parse args ──────────────────────────────────────────────
SKILL=""
OUTCOME="unknown"
DURATION=""
ERROR_DETAIL=""        # DEPRECATED — keep for backward compat
ERROR_CLASS=""         # v2: low-cardinality tag, e.g. "supabase_timeout"
ERROR_MESSAGE=""       # v2: high-cardinality text
STEP=""
SESSION_ID=""
SKILL_VERSION=""       # v2: e.g. "0.1.55"
EVENT_TYPE="skill_run" # v3: skill_run | upgrade_prompted | consent_prompted | ...

while [ $# -gt 0 ]; do
  case "$1" in
    --skill)         SKILL="${2:-}"; shift 2 || break ;;
    --outcome)       OUTCOME="${2:-unknown}"; shift 2 || break ;;
    --duration)      DURATION="${2:-}"; shift 2 || break ;;
    --error-detail)  ERROR_DETAIL="${2:-}"; shift 2 || break ;;     # legacy
    --error-class)   ERROR_CLASS="${2:-}"; shift 2 || break ;;      # v2
    --error-message) ERROR_MESSAGE="${2:-}"; shift 2 || break ;;    # v2
    --step)          STEP="${2:-}"; shift 2 || break ;;
    --session-id)    SESSION_ID="${2:-}"; shift 2 || break ;;
    --skill-version) SKILL_VERSION="${2:-}"; shift 2 || break ;;    # v2
    --event-type)    EVENT_TYPE="${2:-skill_run}"; shift 2 || break ;;  # v3
    *) shift ;;
  esac
done

# Validate event_type — known values only, else fall back
case "$EVENT_TYPE" in
  skill_run|upgrade_prompted|consent_prompted|consent_granted|consent_declined|opt_out|first_run) ;;
  *) EVENT_TYPE="skill_run" ;;
esac

# Backward compat: if legacy --error-detail is used (no class/message),
# treat it as the message. Class stays empty.
if [ -z "$ERROR_MESSAGE" ] && [ -n "$ERROR_DETAIL" ]; then
  ERROR_MESSAGE="$ERROR_DETAIL"
fi

# Skill name is required. Without it the event is useless.
if [ -z "$SKILL" ]; then
  exit 0
fi

# Validate outcome
case "$OUTCOME" in
  success|error|abandoned|unknown) ;;
  *) OUTCOME="unknown" ;;
esac

# ─── State dirs ──────────────────────────────────────────────
STATE_DIR="${SKILL_TELEMETRY_DIR:-$HOME/.${SKILL}}"
ANALYTICS_DIR="$STATE_DIR/telemetry"
JSONL_FILE="$ANALYTICS_DIR/$(date -u +%Y-%m-%d).jsonl"
ID_FILE="$ANALYTICS_DIR/installation-id"

# ─── Self-healing: clear THIS session's pending marker ───────
# The SKILL.md preamble writes a .pending-<session> marker; the
# Final Step is supposed to delete it. If Claude logged a real event
# via this script, the run was NOT skipped — so clear our own marker
# here too (belt-and-suspenders; harmless if the marker is absent).
# We do NOT reap other sessions' markers here — that's the preamble's
# job, and reaping here would risk a recursion (reap → telemetry-log).
if [ -n "$SESSION_ID" ]; then
  rm -f "$ANALYTICS_DIR/pending/.pending-$SESSION_ID" 2>/dev/null || true
fi

mkdir -p "$ANALYTICS_DIR" 2>/dev/null || exit 0

# ─── Installation ID (UUIDv4, generated once per machine per skill) ──
if [ ! -f "$ID_FILE" ]; then
  # Prefer uuidgen, fall back to /proc/sys/kernel/random/uuid, then to a
  # python one-liner, then to a hashed hostname+timestamp as last resort.
  if command -v uuidgen >/dev/null 2>&1; then
    INSTALL_ID="$(uuidgen | tr 'A-Z' 'a-z')"
  elif [ -f /proc/sys/kernel/random/uuid ]; then
    INSTALL_ID="$(cat /proc/sys/kernel/random/uuid)"
  elif command -v python3 >/dev/null 2>&1; then
    INSTALL_ID="$(python3 -c 'import uuid;print(uuid.uuid4())')"
  else
    INSTALL_ID="$(printf '%s-%s' "$(hostname 2>/dev/null || echo host)" "$(date +%s%N 2>/dev/null || date +%s)" | shasum 2>/dev/null | cut -c1-36 || echo "unknown")"
  fi
  echo "$INSTALL_ID" > "$ID_FILE" 2>/dev/null || true
fi
INSTALL_ID="$(cat "$ID_FILE" 2>/dev/null || echo unknown)"

# ─── Anonymous mode: strip the installation ID ───────────────
# We still send the event (counts matter), but the author can't tell
# different users apart. This is the user's chosen middle ground.
if [ "$MODE" = "anonymous" ]; then
  INSTALL_ID=""
fi

# ─── Timestamp ───────────────────────────────────────────────
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

# ─── Platform info (v2) ─────────────────────────────────────
# uname is POSIX, present everywhere. Lowercase for consistency.
OS="$(uname -s 2>/dev/null | tr '[:upper:]' '[:lower:]' || echo unknown)"
ARCH="$(uname -m 2>/dev/null | tr '[:upper:]' '[:lower:]' || echo unknown)"

# ─── Concurrent session count (v3, gstack parity) ───────────
# Touch a per-session marker, then count markers <120min old.
# That's how many concurrent skill runs are active right now.
SESSIONS_DIR="$ANALYTICS_DIR/sessions"
mkdir -p "$SESSIONS_DIR" 2>/dev/null || true
[ -n "$SESSION_ID" ] && touch "$SESSIONS_DIR/$SESSION_ID" 2>/dev/null || true
# Reap stale (>120min) markers, count what's left
find "$SESSIONS_DIR" -type f -mmin +120 -delete 2>/dev/null || true
CONCURRENT_SESSIONS="$(find "$SESSIONS_DIR" -type f 2>/dev/null | wc -l | tr -d ' ' || echo 1)"
[ -z "$CONCURRENT_SESSIONS" ] || [ "$CONCURRENT_SESSIONS" -lt 1 ] && CONCURRENT_SESSIONS=1

# ─── Local-only repo context (v3, gstack parity) ────────────
# Captured in local JSONL for the user's own debugging. Sync STRIPS
# these fields before posting to Supabase — they never leave the
# machine. Author sees aggregate counts; user keeps repo names private.
REPO_SLUG=""
REPO_BRANCH=""
if command -v git >/dev/null 2>&1; then
  REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -n "$REPO_ROOT" ]; then
    REPO_SLUG="$(basename "$REPO_ROOT" 2>/dev/null | tr '[:upper:] ' '[:lower:]-')"
    REPO_BRANCH="$(git branch --show-current 2>/dev/null || true)"
  fi
fi

# ─── Escape strings for JSON ─────────────────────────────────
# Minimal escaping: backslash, double-quote, control chars become spaces.
json_escape() {
  printf '%s' "$1" | sed \
    -e 's/\\/\\\\/g' \
    -e 's/"/\\"/g' \
    -e 's/[[:cntrl:]]/ /g'
}

SKILL_ESC="$(json_escape "$SKILL")"
SKILL_VER_ESC="$(json_escape "$SKILL_VERSION")"
ERROR_CLASS_ESC="$(json_escape "$ERROR_CLASS")"
ERROR_MSG_ESC="$(json_escape "$ERROR_MESSAGE")"
STEP_ESC="$(json_escape "$STEP")"
SESSION_ESC="$(json_escape "$SESSION_ID")"
OS_ESC="$(json_escape "$OS")"
ARCH_ESC="$(json_escape "$ARCH")"
EVENT_TYPE_ESC="$(json_escape "$EVENT_TYPE")"
REPO_SLUG_ESC="$(json_escape "$REPO_SLUG")"
REPO_BRANCH_ESC="$(json_escape "$REPO_BRANCH")"

# Cap error_message at 400 chars (was 160 — give debuggers more room)
if [ ${#ERROR_MSG_ESC} -gt 400 ]; then
  ERROR_MSG_ESC="$(printf '%s' "$ERROR_MSG_ESC" | cut -c1-400)"
fi
# Cap error_class at 60 chars (it should be a short tag, not prose)
if [ ${#ERROR_CLASS_ESC} -gt 60 ]; then
  ERROR_CLASS_ESC="$(printf '%s' "$ERROR_CLASS_ESC" | cut -c1-60)"
fi

# Duration: must be a non-negative integer or "null"
DUR_JSON="null"
if [ -n "$DURATION" ]; then
  case "$DURATION" in
    ''|*[!0-9]*) DUR_JSON="null" ;;
    *) DUR_JSON="$DURATION" ;;
  esac
fi

# Optional string fields: "" → null in JSON
js_field() { [ -n "$1" ] && echo "\"$1\"" || echo "null"; }

ERROR_CLASS_JSON="$(js_field "$ERROR_CLASS_ESC")"
ERROR_MSG_JSON="$(js_field "$ERROR_MSG_ESC")"
STEP_JSON="$(js_field "$STEP_ESC")"
SESSION_JSON="$(js_field "$SESSION_ESC")"
SKILL_VER_JSON="$(js_field "$SKILL_VER_ESC")"
REPO_SLUG_JSON="$(js_field "$REPO_SLUG_ESC")"
REPO_BRANCH_JSON="$(js_field "$REPO_BRANCH_ESC")"

# installation_id: "" → null (anonymous mode), else the UUID
INSTALL_JSON="null"
[ -n "$INSTALL_ID" ] && INSTALL_JSON="\"$INSTALL_ID\""

# ─── Append one JSON line (atomic single-line >> on POSIX) ───
# Schema v3: adds event_type, sessions, source. Plus local-only
# _repo_slug + _branch (telemetry-sync strips these before upload).
# source="live" — telemetry-sync flips this to "replay" if it pushes
# events more than 5 minutes old.
printf '{"v":3,"ts":"%s","event_type":"%s","skill":"%s","skill_version":%s,"outcome":"%s","duration_s":%s,"error_class":%s,"error_message":%s,"step":%s,"session_id":%s,"installation_id":%s,"os":"%s","arch":"%s","sessions":%s,"source":"live","_repo_slug":%s,"_branch":%s}\n' \
  "$TS" "$EVENT_TYPE_ESC" "$SKILL_ESC" "$SKILL_VER_JSON" "$OUTCOME" "$DUR_JSON" \
  "$ERROR_CLASS_JSON" "$ERROR_MSG_JSON" "$STEP_JSON" "$SESSION_JSON" "$INSTALL_JSON" \
  "$OS_ESC" "$ARCH_ESC" "$CONCURRENT_SESSIONS" \
  "$REPO_SLUG_JSON" "$REPO_BRANCH_JSON" \
  >> "$JSONL_FILE" 2>/dev/null || true

# ─── Fire background sync (non-blocking) ─────────────────────
BIN_DIR="${SKILL_TELEMETRY_BIN:-$(cd "$(dirname "$0")" 2>/dev/null && pwd)}"
SYNC="$BIN_DIR/telemetry-sync"
if [ -x "$SYNC" ]; then
  SKILL="$SKILL" "$SYNC" >/dev/null 2>&1 &
fi

# ─── Background update check + gstack-style mode-aware action ──
# Logic:
#   1. Cheap cached check (≤1 GitHub hit / 24h via telemetry-update-check).
#   2. If UPGRADE_AVAILABLE, read user's persistent upgrade-mode choice:
#      - "always": auto-pull silently in background
#      - "never":  log upgrade_prompted event silently, no UX
#      - "ask" (default): emit UPGRADE_PROMPT_NEEDED to stderr so the host
#        skill's preamble (Claude reading SKILL.md) can call AskUserQuestion
#      - "snoozed for this version": treat like "never" until snooze expires
#   3. Recursion-guarded via _SKILL_TELEMETRY_NESTED env.
UPDATE_CHECK="$BIN_DIR/telemetry-update-check"
UPGRADE_DECIDE="$BIN_DIR/telemetry-upgrade-decide"
SHARED_DIR="${SKILL_TELEMETRY_SHARED_DIR:-$HOME/.skill-telemetry}"
MODE_FILE="$SHARED_DIR/.upgrade-mode"
SNOOZE_FILE="$SHARED_DIR/.upgrade-snoozed"

is_version_snoozed() {
  local target="$1"
  [ ! -f "$SNOOZE_FILE" ] && return 1
  local now=$(date +%s)
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    local sver=$(echo "$line" | awk '{print $1}')
    local suntil=$(echo "$line" | awk '{print $2}')
    if [ "$sver" = "$target" ] && [ "$now" -lt "$suntil" ] 2>/dev/null; then
      return 0  # is snoozed
    fi
  done < "$SNOOZE_FILE"
  return 1
}

if [ -x "$UPDATE_CHECK" ] && \
   [ "${SKILL_TELEMETRY_UPDATE:-on}" != "off" ] && \
   [ -z "${_SKILL_TELEMETRY_NESTED:-}" ]; then
  {
    UPDATE_RESULT=$("$UPDATE_CHECK" 2>/dev/null || true)
    case "$UPDATE_RESULT" in
      "UPGRADE_AVAILABLE "*)
        UPD_LOCAL=$(echo "$UPDATE_RESULT" | awk '{print $2}')
        UPD_REMOTE=$(echo "$UPDATE_RESULT" | awk '{print $3}')

        # Always log the upgrade_prompted event (author needs adoption signal)
        _SKILL_TELEMETRY_NESTED=1 "$0" \
          --skill skill-telemetry \
          --event-type upgrade_prompted \
          --outcome unknown \
          --skill-version "$UPD_LOCAL" \
          --step "v${UPD_LOCAL}→v${UPD_REMOTE}" \
          --session-id "tel-update-$(date +%s)" 2>/dev/null

        # Read persistent decision
        MODE="$(cat "$MODE_FILE" 2>/dev/null | tr -d '[:space:]')"
        [ -z "$MODE" ] && MODE="ask"

        # Snooze check
        if is_version_snoozed "$UPD_REMOTE"; then
          MODE="snoozed"
        fi

        case "$MODE" in
          always)
            # Auto-pull silently: pull source repo + run update.
            # Prefer telemetry-update-check's source path; the SRC env
            # variable is detected by skill-telemetry-update.
            UPDATER="$BIN_DIR/skill-telemetry-update"
            if [ -x "$UPDATER" ]; then
              "$UPDATER" --include "$SKILL" >/dev/null 2>&1 || true
            fi
            ;;

          never|snoozed)
            # Silent — only the event was logged above
            ;;

          ask|*)
            # Emit a sentinel on stderr that host skill's preamble watches for.
            # Format: UPGRADE_PROMPT_NEEDED <skill-telemetry-old> <skill-telemetry-new>
            # The host SKILL.md's preamble greps for this and calls AskUserQuestion.
            # Sentinel only printed once per check (controlled by 24h cache).
            echo "UPGRADE_PROMPT_NEEDED $UPD_LOCAL $UPD_REMOTE" >&2
            ;;
        esac
        ;;
    esac
  } &
fi

exit 0
